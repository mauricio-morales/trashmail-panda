{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "TrashMailPanda": "Debug"
    }
  },
  "EmailProvider": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:8080/oauth/callback",
    "TimeoutSeconds": 180
  },
  "LLMProvider": {
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "Temperature": 0.1,
    "MaxTokens": 1000,
    "DailyCostLimit": 10.0
  },
  "StorageProvider": {
    "DatabasePath": "./data/transmail.db",
    "EncryptionKey": "",
    "EnableWAL": true,
    "CommandTimeoutSeconds": 30
  },
  "ContactsProvider": {
    "TimeoutSeconds": 120,
    "MaxRetryAttempts": 3,
    "RetryDelayMilliseconds": 1000,
    "IsEnabled": true
  },
  "GoogleServicesProvider": {
    "Name": "GoogleServices",
    "IsEnabled": true,
    "TimeoutSeconds": 300,
    "MaxRetryAttempts": 5,
    "RetryDelayMilliseconds": 1000,
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:8080/oauth/callback",
    "ApplicationName": "TrashMail Panda",
    "EnableGmail": true,
    "EnableContacts": true,
    "GmailRequestTimeout": "00:02:00",
    "GmailMaxRetries": 5,
    "GmailBaseRetryDelay": "00:00:01",
    "GmailMaxRetryDelay": "00:02:00",
    "GmailEnableBatchOptimization": true,
    "GmailBatchSize": 50,
    "GmailDefaultPageSize": 100,
    "ContactsRequestTimeout": "00:01:00",
    "ContactsMaxRetries": 5,
    "ContactsBaseRetryDelay": "00:00:01",
    "ContactsMaxRetryDelay": "00:01:00",
    "ContactsDefaultPageSize": 1000,
    "ContactsCachingEnabled": true,
    "ContactsEnableBackgroundSync": true,
    "ContactsBackgroundSyncInterval": "04:00:00",
    "ContactsEnableTrustSignals": true,
    "ContactsTrustSignalCacheExpiry": "1.00:00:00"
  }
}